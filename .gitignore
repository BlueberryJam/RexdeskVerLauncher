# Local version-manager data
# Share notes, but keep installed app copies, MSI binaries, logs, backups,
# and catalogs with machine-specific absolute paths out of git.
rexdesk-version-manager/library/**
!rexdesk-version-manager/library/
!rexdesk-version-manager/library/*/
!rexdesk-version-manager/library/*/bug_notes/
!rexdesk-version-manager/library/*/bug_notes/*.txt
!rexdesk-version-manager/library/*/patch_notes/
!rexdesk-version-manager/library/*/patch_notes/*.txt
!rexdesk-version-manager/library/*/msi/
!rexdesk-version-manager/library/*/msi/*_notes.txt

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
.env

# PyInstaller / local builds
build/
dist/
*.spec.bak

# Logs / IDE
debug*.log
.cursor/

# Local installed app copies and logs
library/*/installs/
library/*/_backup/
library/*/*.log
